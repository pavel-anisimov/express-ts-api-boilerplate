{
  "name": "express-ts-api-boilerplate",
  "version": "0.1.0",
  "private": true,
  "author": {
    "name": "Pavel Anisimov",
    "email": "pavel.n.anisimov@gmail.com",
    "url": "https://pavel.us"
  },
  "homepage": "https:/pavel.us",
  "license": "MIT",
  "description": "Node + Express + TypeScript API with ESLint",
  "type": "module",
  "engines": {
    "node": ">=22.22.0",
    "npm": ">=11.0.0"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "keywords": [
    "Node",
    "Express",
    "TypeScript",
    "API"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pavel-anisimov/express-ts-api-boilerplate"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "http-proxy-middleware": "^4.0.0",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "swagger-jsdoc": "^7.0.0-rc.6",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bcryptjs": "^3.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^4.0.0-alpha.13",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.22.3",
    "typescript-eslint": "^8.60.0",
    "typescript": "^6.0.3",
    "vitest": "^5.0.0-beta.3"
  }
}
